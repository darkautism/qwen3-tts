[Unit]
Description=Qwen3-TTS Frontend (OpenAI API + Web UI)
After=network-online.target qwen3-tts-talker.service qwen3-tts-predictor.service qwen3-tts-vocoder.service
Wants=network-online.target

[Service]
Type=simple
Environment=HOME=%h
Environment=XDG_CONFIG_HOME=%h/.config
Environment=QWEN3_TTS_BIN=%h/.local/bin/qwen3-tts
Environment=QWEN3_TTS_SERVE_PORT=8080
EnvironmentFile=-%h/.config/qwen3-tts/systemd.env
WorkingDirectory=%h/.config/qwen3-tts
ExecStartPre=/usr/bin/mkdir -p %h/.config/qwen3-tts
ExecStartPre=/usr/bin/test -f %h/.config/qwen3-tts/config.toml
ExecStart=/usr/bin/bash -lc '"${QWEN3_TTS_BIN}" serve --port "${QWEN3_TTS_SERVE_PORT}"'
Restart=always
RestartSec=2
NoNewPrivileges=true

[Install]
WantedBy=default.target
